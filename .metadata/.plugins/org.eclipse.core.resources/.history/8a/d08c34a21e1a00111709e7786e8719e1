/*
 * @GPIO_PIN_MODES
 * GPIO pin possible modes as per Moder resgister which is the first peripheral
 */
#define GPIO_MODE_IN  		0
#define GPIO_MODE_OUT 		1
#define GPIO_MODE_ALTFN		2
#define GPIO_MODE_ANALOG	3
#define GPIO_MODE_IT_FT		4
#define GPIO_MODE_IT_RT		5
#define GPIO_MODE_IT_RFT	6

/*
 *	 GPIO pin possible output type second peripheral for GPIO
 */
#define GPIO_OP_TYPE_PP		0
#define GPIO_OP_TYPE_OD		1

/*
 * GPIO output speed register possible values to configure output speed
 */
#define GPIO_SPEED_LOW		0
#define GPIO_SPEED_MEDIUM	1
#define GPIO_SPEED_FAST		2
#define GPIO_SPEED_HIGH 	3
/*
 * GPIO pull up and pull down configuration macros
 */
#define GPIO_NO_PUPD		0
#define GPIO_PU				1
#define GPIO_PD				2


/*
 * GPIO handle structure
 */
typedef struct{
	GPIO_RegDef_t    *pGPIOx;
	GPIO_PinConfig_t *GPIO_PinConfig;/* This holds the base address of GPIO port to which pin belongs*/
}GPIO_Handle_t;

